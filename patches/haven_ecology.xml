<?xml version="1.0" encoding="UTF-8"?>
<Patch>

	<!--
	  ════════════════════════════════════════════════════════════════════════
	  Closed Loop Ecology

	  Six surgical patches that close the food/carbon/chemicals cycle:

	  §1  Carbon and Raw Chemicals minable at reasonable levels
	  §2  Composter retains realistic amounts of carbon (×6 boost)
	  §3  CO2 scrubber rebalanced to be the exact inverse of the carbon burner
	  §4  New recipe: Industrial Chemicals Synthesis (on Chemical Refinery)
	  §5  New recipe: Biomass Pyrolysis (on dedicated new Pyrolysis Reactor)
	  §6  New station: Pyrolysis Reactor (1×1 buildable, hosts both pyrolysis
	      and the non-interactive char-residue → CO2 vent)
	  ════════════════════════════════════════════════════════════════════════
	-->


	<!-- ════════════════════════════════════════════════════════════════════
	     SECTION 1: Carbon and Raw Chemicals minable at reasonable levels
	     ════════════════════════════════════════════════════════════════════ -->

	<Operation Class="AttributeSet">
		<xpath>/data/Product/product[@eid='170']/mineable/difficulty</xpath>
		<attribute>level</attribute>
		<value>2</value>
	</Operation>
	<Operation Class="AttributeSet">
		<xpath>/data/Product/product[@eid='171']/mineable/difficulty</xpath>
		<attribute>level</attribute>
		<value>3</value>
	</Operation>


	<!-- ════════════════════════════════════════════════════════════════════
	     SECTION 2: Composter retains realistic amounts of carbon (×6 boost)
	     ════════════════════════════════════════════════════════════════════ -->

	<Operation Class="AttributeSet">
		<xpath>/data/Product/product[@eid='2467']/products/l[@element='170']</xpath>
		<attribute>produceEvery</attribute>
		<value>10</value>
	</Operation>
	<Operation Class="AttributeSet">
		<xpath>/data/Product/product[@eid='2472']/products/l[@element='170']</xpath>
		<attribute>produceEvery</attribute>
		<value>8</value>
	</Operation>
	<Operation Class="AttributeSet">
		<xpath>/data/Product/product[@eid='2463']/products/l[@element='170']</xpath>
		<attribute>produceEvery</attribute>
		<value>8</value>
	</Operation>
	<Operation Class="AttributeSet">
		<xpath>/data/Product/product[@eid='2468']/products/l[@element='170']</xpath>
		<attribute>produceEvery</attribute>
		<value>8</value>
	</Operation>
	<Operation Class="AttributeSet">
		<xpath>/data/Product/product[@eid='2897']/products/l[@element='170']</xpath>
		<attribute>produceEvery</attribute>
		<value>8</value>
	</Operation>
	<Operation Class="AttributeSet">
		<xpath>/data/Product/product[@eid='2478']/products/l[@element='170']</xpath>
		<attribute>produceEvery</attribute>
		<value>4</value>
	</Operation>
	<Operation Class="AttributeSet">
		<xpath>/data/Product/product[@eid='2471']/products/l[@element='170']</xpath>
		<attribute>produceEvery</attribute>
		<value>16</value>
	</Operation>
	<Operation Class="AttributeSet">
		<xpath>/data/Product/product[@eid='2473']/products/l[@element='170']</xpath>
		<attribute>produceEvery</attribute>
		<value>16</value>
	</Operation>


	<!-- ════════════════════════════════════════════════════════════════════
	     SECTION 3: CO2 scrubber = exact inverse of carbon burner
	       Burner (recipe 65):  0.0025 C → 50 CO2  per cycle
	       Scrubber (recipe 66):    50 CO2 → 0.0025 C  per cycle
	     ════════════════════════════════════════════════════════════════════ -->

	<Operation Class="AttributeSet">
		<xpath>/data/Product/product[@eid='66']/needs/l[@element='64']</xpath>
		<attribute>howMuch</attribute>
		<value>50</value>
	</Operation>
	<Operation Class="AttributeSet">
		<xpath>/data/Product/product[@eid='66']/products/l[@element='170']</xpath>
		<attribute>produceEvery</attribute>
		<value>400</value>
	</Operation>


	<!-- ════════════════════════════════════════════════════════════════════
	     SECTION 4: New recipe — Industrial Chemicals Synthesis
	     Hosted on Chemical Refinery (mid 939) via dispatcher 963.
	     Item-only outputs (no O2 byproduct) so conditional UI works.
	     ════════════════════════════════════════════════════════════════════ -->

	<Operation Class="NodeAdd">
		<xpath>/data/Product</xpath>
		<value>
			<product eid="7700001" type="Process" interactive="true"
			         startOnly="false" itemScrapper="false" smelter="false"
			         scrapper="false" composter="false"
			         processValue="100" customPriority="-1">
				<name tid="7700095"/>                                 <!-- "Industrial Chemicals Synthesis" -->
				<GUIAnimation aid="chemicalsIcon1"/>
				<sort s="3" p="20"/>
				<needs>
					<l element="170" howMuch="1" consumeEvery="1"/>
					<l element="16"  howMuch="3" consumeEvery="1"/>
				</needs>
				<products>
					<l element="176" howMuch="3" produceEvery="1"/>
				</products>
				<accidentList listId="3146"/>
				<difficulty skill="Industry" level="2">
					<custom time="25"/>
				</difficulty>
				<desc/>
			</product>
		</value>
	</Operation>
	<Operation Class="NodeAdd">
		<xpath>/data/Product/product[@eid='963']/list/processes</xpath>
		<value>
			<l process="7700001"/>
		</value>
	</Operation>


	<!-- ════════════════════════════════════════════════════════════════════
	     SECTION 5: Pyrolysis recipes (char residue item + interactive recipe
	     + non-interactive auto-vent recipe + dispatcher for the interactive)

	     These DO NOT attach to vanilla stations.  They're hosted on the new
	     Pyrolysis Reactor station defined in §6.
	     ════════════════════════════════════════════════════════════════════ -->

	<!-- 5a. Char Residue item (transient inventory item; gets auto-vented to CO2) -->
	<Operation Class="NodeAdd">
		<xpath>/data/Product</xpath>
		<value>
			<product eid="7700020" type="Elementary" item="0" elementType="Defined">
				<name tid="7700092"/>                                 <!-- "Char Residue" -->
				<GUIAnimation aid="rubbleIcon1"/>
				<sort s="3" p="25"/>
				<desc tid="7700093"/>
			</product>
		</value>
	</Operation>

	<!-- 5b. Interactive Biomass Pyrolysis recipe.
	     Crew at the Pyrolysis Reactor runs this.  Item-only outputs so the
	     "produce if storage < X" condition works on either carbon or char. -->
	<Operation Class="NodeAdd">
		<xpath>/data/Product</xpath>
		<value>
			<product eid="7700010" type="Process" interactive="true"
			         startOnly="false" itemScrapper="false" smelter="false"
			         scrapper="false" composter="false"
			         processValue="100" customPriority="-1">
				<name tid="7700094"/>                                 <!-- "Biomass Pyrolysis" -->
				<GUIAnimation aid="carbonIcon1"/>
				<sort s="3" p="20"/>
				<needs>
					<l element="71"      howMuch="2" consumeEvery="1"/>
				</needs>
				<products>
					<l element="170"     howMuch="1" produceEvery="1"/>
					<l element="7700020" howMuch="1" produceEvery="1"/>
				</products>
				<accidentList listId="3146"/>
				<difficulty skill="Industry" level="1">
					<custom time="25"/>
				</difficulty>
				<desc/>
			</product>
		</value>
	</Operation>

	<!-- 5c. Non-interactive char residue → CO2 vent recipe.
	     Auto-runs at the Pyrolysis Reactor whenever char residue is in storage. -->
	<Operation Class="NodeAdd">
		<xpath>/data/Product</xpath>
		<value>
			<product eid="7700022" type="Process" interactive="false"
			         startOnly="false" itemScrapper="false" smelter="false"
			         scrapper="false" composter="false"
			         processValue="100" customPriority="-1">
				<name tid="100"/>
				<GUIAnimation aid="co2ResourceIcon"/>
				<needs>
					<l element="7700020" howMuch="1"  consumeEvery="1"/>
				</needs>
				<products>
					<l element="64"      howMuch="50" produceEvery="1"/>
				</products>
				<desc/>
			</product>
		</value>
	</Operation>

	<!-- 5d. Dispatcher for the interactive pyrolysis recipe.
	     The Pyrolysis Reactor's <produces> references this so crew can select
	     it in the station UI (same pattern as vanilla Chemical Refinery uses
	     dispatcher 963). -->
	<Operation Class="NodeAdd">
		<xpath>/data/Product</xpath>
		<value>
			<product eid="7700040" type="Process" interactive="true"
			         startOnly="false" itemScrapper="false" smelter="true"
			         scrapper="false" composter="false"
			         processValue="100" customPriority="-1">
				<name tid="7700094"/>                                 <!-- "Biomass Pyrolysis" -->
				<GUIAnimation aid="carbonIcon1"/>
				<sort s="3" p="20"/>
				<needs/>
				<products/>
				<list>
					<processes>
						<l process="7700010"/>
					</processes>
				</list>
				<desc/>
			</product>
		</value>
	</Operation>


	<!-- ════════════════════════════════════════════════════════════════════
	     SECTION 6: New buildable station — Pyrolysis Reactor (mid 7700050)

	     Cloned from the Water Collector (mid 2451, 1×1 RESOURCE-category
	     buildable).  Visual reuses waterCollector1F sprites — distinct from
	     Composter and Chemical Refinery so players can tell them apart.

	     Hosts two recipes:
	       - dispatcher 7700040  (interactive pyrolysis, crew operated)
	       - recipe 7700022      (auto-vent char residue → CO2, atmospheric)
	     ════════════════════════════════════════════════════════════════════ -->

	<Operation Class="NodeAdd">
		<xpath>/data/Element</xpath>
		<value>
			<me mid="7700050" ec="2" costGroup="875" offsetRot="R0" nonSymmetrical="false" alternateY="false">
				<data>
					<l type="Object" eid="1" gridOffX="0" gridOffY="0" layer="0">
						<element id="0" renderOnFloor="false" renderOnFloorPartially="false" noMoveDismantle="false" cannotBeSelected="false" walkGridCost="255" lightValue="High">
							<definedStates>
								<l state="InUse" playAnimation="true">
									<r0 aid="waterCollector1F" flx="true"/>
									<r90 aid="null" flx="false"/>
									<r180 aid="waterCollector1B" flx="false"/>
									<r270 aid="null" flx="false"/>
								</l>
								<l state="Standby" playAnimation="true">
									<r0 aid="waterCollector1F" flx="true"/>
									<r90 aid="null" flx="false"/>
									<r180 aid="waterCollector1B" flx="false"/>
									<r270 aid="null" flx="false"/>
								</l>
							</definedStates>
							<additionaFullLit x="0" y="0" mirX="0" mirY="0" atNoPower="false" atStandby="true" atInuse="true">
								<r0 aid="waterCollector1FLights" flx="true"/>
								<r90 aid="null" flx="false"/>
								<r180 aid="waterCollector1BLights" flx="false"/>
								<r270 aid="null" flx="false"/>
							</additionaFullLit>
							<features addFacilityIcons="true" noPressureDmg="false" normalState="true" produceInNormal="false" inUseState="true">
								<produces>
									<!-- Interactive pyrolysis (via dispatcher 7700040) — crew operated -->
									<l valuePerSec="10" product="7700040" basicPowerUsage="1.5" useHighCapPowerPerSec="100.0" powerCategory="Industry" suction="false">
										<heat type="HeatTo" temp="Medium"/>
										<gas hazardGasPerSec="2"/>
									</l>
									<!-- Non-interactive char-residue vent — auto-runs when residue in storage -->
									<l valuePerSec="50" product="7700022" basicPowerUsage="0.5" useHighCapPowerPerSec="0.0" powerCategory="Facilities" suction="false">
										<logic resource="7700020" is="GreaterThan" value="0"/>
										<heat type="HeatTo" temp="Low"/>
									</l>
								</produces>
								<stateWatchdog autoproduce="true"/>
								<environment repairBlockFail="0.1" coldOffTempC="-100" coldSlowTempC="0" hotSlowTempC="60" hotOffTempC="200" coldTempSlowdown="0.8" hotTempSlowdown="1.0" cyclesForDmg="100" cyclesDmgChance="0.1" hazTimeDmg="360" hazDmgChance="0.5" waterTimeDmg="360" waterDmgChance="0.0" tempTimeDmg="360" tempDmgChance="0.1"/>
								<noiseAndComfort onlyWhenInuse="false" category="ObjectId">
									<noise ignoreZoomLevel="false" noise="10.0">
										<audio auid="null"/>
									</noise>
									<constantSound>
										<atStandby auid="4308"/>
										<atInUse auid="4308"/>
									</constantSound>
									<radiusBeauty roomDrop="15" work="-6" sleep="-20" leisure="-10" radius="4"/>
								</noiseAndComfort>
							</features>
							<boxHatch x="17" y="-2" boxX="17" boxY="-2" in="true" out="true" flipR90="false" type2="false" wallHatch="false">
								<activate activateOffX="0" activateOffY="-1"/>
							</boxHatch>
							<commonPower powerCategory="Industry"/>
						</element>
					</l>
				</data>
				<linked/>
				<events/>
				<objectInfo placeInMenu="5" disableRotation="false" disableBuildTest="false" buildInstant="false" disableAirlockTest="false" debugOnly="false" canDismantleOnly="false" randomRot="false" viewMode="Normal" systemPoints="0" canBuildAt="All" outdoorObject="false" indoorObject="true">
					<cu>
						<groups>
							<l rep="875" buildTools="15">
								<customPrice>
									<l elementId="162" howMuch="2"/>
									<l elementId="930" howMuch="2"/>
								</customPrice>
							</l>
						</groups>
					</cu>
					<name tid="7700090"/>                                 <!-- "Pyrolysis Reactor" -->
					<desc tid="7700091"/>                                 <!-- "Thermally decomposes biomass..." -->
					<guiIcon aid="build_icon_2451"/>
					<subCat id="1510"/>
					<difficultyLevel skill="Construction" level="3"/>
					<restrictions>
						<l type="Floor" gridX="0" gridY="-1" sizeX="1" sizeY="1"/>
					</restrictions>
				</objectInfo>
			</me>
		</value>
	</Operation>

</Patch>
